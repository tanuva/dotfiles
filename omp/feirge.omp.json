{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "white": "#FFFFFF",
    "tan": "#CC3802",
    "teal": "#047E84",
    "plum": "#9A348E",
    "blush": "#DA627D",
    "salmon": "#FCA17D",
    "sky": "#86BBD8",
    "teal_blue": "#33658A",
    "pink": "#ff75a2",
    "dark_pink": "#ee6d98",
    "purple": "#be19d6",
    "blue": "#333ebd"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "foreground": "#fff",
          "background": "p:dark_pink",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": "{{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        },
        {
          "template": " \uf0e7 ",
          "foreground": "#100e23",
          "powerline_symbol": "\ue0b0",
          "background": "#ffe9aa",
          "type": "root",
          "style": "powerline"
        },
        {
          "options": {
            "folder_icon": "\uf115",
            "folder_separator_icon": " \ue0b1 ",
            "style": "full"
          },
          "template": " {{ .Path }} ",
          "foreground": "#fff",
          "powerline_symbol": "\ue0b0",
          "background": "p:purple",
          "type": "path",
          "style": "powerline"
        },
        {
          "template": " {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }} {{ end }} ",
          "foreground": "#fff",
          "powerline_symbol": "\ue0b0",
          "background": "p:blue",
          "type": "git",
          "style": "powerline",
          "options": {

          }
        },
        {
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "foreground": "#100e23",
          "powerline_symbol": "\ue0b0",
          "background": "#906cff",
          "type": "python",
          "style": "powerline"
        },
        {
          "template": " \ue20f ",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "p:dark_pink",
          "type": "status",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "❯ ",
          "foreground": "p:pink",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ],
  "version": 1
}
