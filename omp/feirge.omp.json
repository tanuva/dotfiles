{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "host_segment": "#6D0202",
    "path_segment": "#F2780C",
    "git_segment": "#F2A20C",
    "prompt_indicator": "#F2780C"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "foreground": "#fff",
          "background": "p:host_segment",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": "{{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        },
        {
          "template": " \uf0e7 ",
          "foreground": "#100e23",
          "powerline_symbol": "\ue0b0",
          "background": "#ffe9aa",
          "type": "root",
          "style": "powerline"
        },
        {
          "options": {
            "folder_icon": "\uf115",
            "folder_separator_icon": " \ue0b1 ",
            "style": "full"
          },
          "template": " {{ .Path }} ",
          "foreground": "#fff",
          "powerline_symbol": "\ue0b0",
          "background": "p:path_segment",
          "type": "path",
          "style": "powerline"
        },
        {
          "template": " {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }} {{ end }} ",
          "foreground": "#fff",
          "powerline_symbol": "\ue0b0",
          "background": "p:git_segment",
          "type": "git",
          "style": "powerline",
          "options": {}
        },
        {
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "foreground": "#100e23",
          "powerline_symbol": "\ue0b0",
          "background": "#906cff",
          "type": "python",
          "style": "powerline"
        },
        {
          "template": " \ue20f ",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "p:dark_pink",
          "type": "status",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "❯ ",
          "foreground": "p:prompt_indicator",
          "type": "text",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ],
  "version": 1
}
